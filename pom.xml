            <plugin>
                <groupId>org.springframework.boot</groupId>
                <artifactId>spring-boot-maven-plugin</artifactId>
                <!-- configuration/excludes 打包时排除 lombok 依赖，因为它只在编译期生效，
                运行期不需要，避免 jar 包变大 -->
                <configuration>
                    <!-- 打包时排除 Lombok，避免冗余 -->
                    <excludes>
                        <exclude>
                            <groupId>org.projectlombok</groupId>
                            <artifactId>lombok</artifactId>
                        </exclude>
                    </excludes>
                </configuration>
                <!--   executions/execution 绑定 repackage 目标，
                确保 mvn package 生成的是可直接运行的可执行 Jar，而不是普通的依赖 Jar  -->
                <executions>
                    <!-- 绑定到构建生命周期，确保打包可执行 Jar -->
                    <execution>
                        <goals>
                            <goal>repackage</goal>
                        </goals>
                    </execution>
                </executions>
            </plugin>
        </plugins>
    </build>


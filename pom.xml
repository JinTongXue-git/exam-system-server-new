        <!-- ====================== 【核心】拆散版 AOP 依赖 - 100%适配 SpringBoot 4.0.6 + JDK21 ====================== -->
        <!-- 说明：彻底抛弃 spring-boot-starter-aop 起步依赖，拆分出底层4个核心包，无自动配置冲突，无版本报错 -->

        <!-- 1. Spring AOP 核心模块（必须导入）
             版本：6.1.14 → 严格匹配 SpringBoot 4.0.6 底层的 Spring Framework 版本（官方强制对应）
             作用：提供 Spring 原生的 AOP 核心能力、动态代理基础功能，是整个 AOP 的根基 -->
        <dependency>
            <groupId>org.springframework</groupId>
            <artifactId>spring-aop</artifactId>
            <version>6.1.14</version>
        </dependency>

        <!-- 2. Spring 整合 AspectJ 专用模块（必须导入）
             版本：与 spring-aop 完全一致 6.1.14，保证同框架无版本冲突
             作用：让 Spring 支持 @Aspect、@Before、@Around 等 AspectJ 注解，没有这个包，切面注解完全不生效 -->
        <dependency>
            <groupId>org.springframework</groupId>
            <artifactId>spring-aspects</artifactId>
            <version>6.1.14</version>
        </dependency>

        <!-- 3. AspectJ 核心织入器（必须导入，AOP 灵魂包）
             版本：1.9.22.1 → Spring 官方指定兼容 Spring6 + JDK17+/21 的稳定版本
             作用：解析切面注解、执行切点表达式、把增强逻辑织入目标方法，没有这个包，AOP 无法运行 -->
        <dependency>
            <groupId>org.aspectj</groupId>
            <artifactId>aspectjweaver</artifactId>
            <version>1.9.22.1</version>
        </dependency>

        <!-- 4. AspectJ 运行时依赖（必须导入，JDK21 兼容必备）
             版本：与 aspectjweaver 完全一致，保证组件统一
             作用：提供 AspectJ 运行时环境，解决 JDK21 字节码代理兼容问题，避免启动报错、类格式异常
             scope：runtime → 只在运行时生效，不参与编译，精简项目依赖 -->
        <dependency>
            <groupId>org.aspectj</groupId>
            <artifactId>aspectjrt</artifactId>
            <version>1.9.22.1</version>
            <scope>runtime</scope>
        </dependency>







        <!-- 监控（可选）
         Spring Boot 4.0 里它是不是默认自带？
         不是默认自带，它是一个可选 starter，和 Spring Boot 3.x 一样，必须手动引入才会生效。
         它的作用：提供健康检查、指标监控、环境信息等端点（比如 /actuator/health），属于运维 / 监控扩展功能，不是 Web 应用的核心依赖。
         你不引它，项目也能正常跑，只是没有这些监控端点而已。
         -->
        <dependency>
